local Library = loadstring(game:HttpGet(" https://raw.githubusercontent.com/phamquochoa1942-png/uinova/refs/heads/main/UILibrary.lua"))()

-- OR if in same script:
-- local Library = require(script.NovaLib)

local Win = Library:CreateWindow({
    Title    = "Blox Fruits",
    Subtitle  = "Nova UI v2.0",
    Size     = UDim2.new(0, 620, 0, 420),
})

local Main = Win:AddTab("⚔️  Combat")
local Farm = Win:AddTab("🌾  Farm")
local Misc = Win:AddTab("⚙️  Misc")

Main:AddSection("Aimbot Settings")

Main:AddToggle("Auto Attack", false, function(state)
    print("Auto Attack:", state)
end)

Main:AddDropdown("Target Mode", {"Nearest", "Lowest HP", "Boss"}, "N/A", function(val)
    print("Target:", val)
end)

Main:AddSlider("Attack Speed", 0, 100, 50, function(val)
    print("Speed:", val)
end)

Main:AddSection("Skills")

Main:AddToggle("Auto Skill", false, function(state)
    print("Auto Skill:", state)
end)

Main:AddButton("Kill All", function()
    print("Kill All triggered!")
end)

Farm:AddSection("Auto Farm")

Farm:AddToggle("Auto Farm", false, function(state)
    print("Farm:", state)
end)

Farm:AddDropdown("Island", {"Starter", "Middle", "Upper", "Sky Island"}, "N/A", function(val)
    print("Island:", val)
end)

Farm:AddButton("Teleport Here", function()
    print("Teleporting...")
end)

Misc:AddSection("Keybinds")

Misc:AddKeybind("Toggle UI", Enum.KeyCode.RightShift, function(k)
    print("Key pressed:", k)
end)

Misc:AddTextbox("Custom Value", "Type here...", function(text)
    print("Input:", text)
end)
 
